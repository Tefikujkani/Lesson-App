# Required: Groq API key (free) — https://console.groq.com
GROQ_API_KEY=

# Required: MongoDB connection string (Atlas or local)
MONGODB_URI=

# Required: secret used to sign login JWTs (use a long random string)
JWT_SECRET=change-me-to-a-long-random-secret

# Google / Gmail sign-in (Web OAuth Client ID from Google Cloud Console)
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
